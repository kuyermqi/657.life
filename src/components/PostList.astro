---
import type { CollectionEntry } from "astro:content";

type Post = CollectionEntry<"posts">;

interface Props {
  posts: Post[];
  filterable?: boolean;
  flushTop?: boolean;
}

const { posts, filterable = false, flushTop = false } = Astro.props;
---

<ul class:list={["post-list", { "post-list-flush-top": flushTop }]} data-post-list={filterable ? "" : undefined}>
  {
    posts.map((post: Post) => {
      const formattedDate = post.data.date.toLocaleDateString("en", {
        year: "numeric",
        month: "long",
        day: "numeric",
      });
      const itemAttrs = filterable
        ? {
            "data-post-item": "",
            "data-categories": JSON.stringify(post.data.categories),
            "data-tags": JSON.stringify(post.data.tags),
          }
        : {};

      return (
        <li class="post-item" {...itemAttrs}>
          <a href={`/posts/${post.id}`}>
            <span class="post-title">{post.data.title}</span>
            <span class="post-description">{post.data.description}</span>
            <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
          </a>
        </li>
      );
    })
  }
</ul>

<style>
  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) 0;
    text-decoration: none;
    color: var(--color-text);
  }

  .post-list-flush-top .post-item:first-child a {
    padding-top: 0;
  }

  .post-item a:hover .post-title {
    color: var(--color-text-secondary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
  }
</style>
