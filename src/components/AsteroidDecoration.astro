<section class="asteroid-decoration" aria-hidden="true" data-asteroid-decoration>
  <canvas data-asteroid-canvas></canvas>
</section>

<script is:inline>
  (() => {
    const decorations = document.querySelectorAll("[data-asteroid-decoration]");

    for (const decoration of decorations) {
      const canvas = decoration.querySelector("[data-asteroid-canvas]");
      const ctx = canvas?.getContext("2d", { alpha: false });

      if (!canvas || !ctx) {
        continue;
      }

      const pPlanetRadius = 1.1;
      const pRingSize = 1;
      const AUTO_ROTATION_PERIOD_SECONDS = 60;
      const AUTO_ROTATION_SPEED = (Math.PI * 2) / AUTO_ROTATION_PERIOD_SECONDS;
      const AUTO_AXIS_SPEED = AUTO_ROTATION_SPEED / Math.sqrt(2);
      const AUTO_YAW_SPEED = -AUTO_AXIS_SPEED;
      const AUTO_PITCH_SPEED = AUTO_AXIS_SPEED;
      let pCamDist = window.matchMedia("(max-width: 640px)").matches ? 7 : 3.5;

      let vRotX = 0;
      let vRotY = 0;
      let vZoom = 0;
      let lastMoveTime = 0;
      let isDragging = false;
      let lastX = 0;
      let lastY = 0;
      let initialPinchDist = null;

      let initPitch = -0.5;
      let initYaw = 0.6;
      let pitchMat = createRotationMatrix([1, 0, 0], initPitch);
      let yawMat = createRotationMatrix([0, 1, 0], initYaw);
      let rotMatrix = multiplyMatrix(pitchMat, yawMat);

      const CHARS = "@@%#*+=-:.  ";
      const activePointers = new Map();
      let cellW = 8;
      let cellH = 16;
      let cols = 1;
      let rows = 1;
      let rays = [];
      let backgroundDots = [];
      let cssWidth = 1;
      let cssHeight = 1;
      let time = 0;
      let lastFrameMs = null;

      function multiplyMatrix(a, b) {
        let res = new Array(9);
        for (let i = 0; i < 3; i++) {
          for (let j = 0; j < 3; j++) {
            res[i * 3 + j] = a[i * 3 + 0] * b[0 * 3 + j] + a[i * 3 + 1] * b[1 * 3 + j] + a[i * 3 + 2] * b[2 * 3 + j];
          }
        }
        return res;
      }

      function createRotationMatrix(axis, angle) {
        let c = Math.cos(angle);
        let s = Math.sin(angle);
        let t = 1 - c;
        let x = axis[0];
        let y = axis[1];
        let z = axis[2];
        return [
          t * x * x + c, t * x * y - s * z, t * x * z + s * y,
          t * x * y + s * z, t * y * y + c, t * y * z - s * x,
          t * x * z - s * y, t * y * z + s * x, t * z * z + c,
        ];
      }

      function length(v) {
        return Math.sqrt(v[0] * v[0] + v[1] * v[1] + v[2] * v[2]);
      }

      function normalize(v) {
        let l = length(v);
        return l === 0 ? [0, 0, 0] : [v[0] / l, v[1] / l, v[2] / l];
      }

      function orthogonalize(m) {
        let r0 = normalize([m[0], m[1], m[2]]);
        let dot01 = r0[0] * m[3] + r0[1] * m[4] + r0[2] * m[5];
        let r1 = normalize([m[3] - dot01 * r0[0], m[4] - dot01 * r0[1], m[5] - dot01 * r0[2]]);
        let r2 = [
          r0[1] * r1[2] - r0[2] * r1[1],
          r0[2] * r1[0] - r0[0] * r1[2],
          r0[0] * r1[1] - r0[1] * r1[0],
        ];
        return [
          r0[0], r0[1], r0[2],
          r1[0], r1[1], r1[2],
          r2[0], r2[1], r2[2],
        ];
      }

      function transformPoint(m, p) {
        return [
          m[0] * p[0] + m[1] * p[1] + m[2] * p[2],
          m[3] * p[0] + m[4] * p[1] + m[5] * p[2],
          m[6] * p[0] + m[7] * p[1] + m[8] * p[2],
        ];
      }

      function applyDrag(dx, dy) {
        let len = Math.sqrt(dx * dx + dy * dy);
        if (len > 0.01) {
          let axis = [dy / len, -dx / len, 0];
          let angle = -len * 0.005;
          let deltaMat = createRotationMatrix(axis, angle);
          rotMatrix = multiplyMatrix(rotMatrix, deltaMat);
          rotMatrix = orthogonalize(rotMatrix);
        }
      }

      function applyAutoRotation(deltaSeconds) {
        if (deltaSeconds <= 0) {
          return;
        }

        let pitchDelta = createRotationMatrix([1, 0, 0], AUTO_PITCH_SPEED * deltaSeconds);
        let yawDelta = createRotationMatrix([0, 1, 0], AUTO_YAW_SPEED * deltaSeconds);
        rotMatrix = multiplyMatrix(rotMatrix, pitchDelta);
        rotMatrix = multiplyMatrix(rotMatrix, yawDelta);
        rotMatrix = orthogonalize(rotMatrix);
      }

      function dot(a, b) {
        return a[0] * b[0] + a[1] * b[1] + a[2] * b[2];
      }

      function rotateY(p, a) {
        let s = Math.sin(a);
        let c = Math.cos(a);
        return [p[0] * c + p[2] * s, p[1], -p[0] * s + p[2] * c];
      }

      function map(p) {
        let pt = transformPoint(rotMatrix, p);

        let pAst = rotateY(pt, time * 0.4);
        let dAst = length(pAst) - pPlanetRadius;

        let pRing = rotateY(pt, time * 0.15);
        let lXz = Math.sqrt(pRing[0] ** 2 + pRing[2] ** 2);

        let ringInner = pPlanetRadius * 1.5 * pRingSize;
        let ringOuter = pPlanetRadius * 2.4 * pRingSize;
        let ringMid = (ringInner + ringOuter) / 2;
        let ringWidth = (ringOuter - ringInner) / 2;

        let dRing = Math.max(Math.abs(lXz - ringMid) - ringWidth, Math.abs(pRing[1]) - 0.015);
        let gapPos = ringInner + (ringOuter - ringInner) * 0.4;
        dRing = Math.max(dRing, -(Math.abs(lXz - gapPos) - 0.04 * pRingSize));

        if (dAst < dRing) return { d: dAst, id: 1 };
        return { d: dRing, id: 2 };
      }

      function mapD(p) {
        return map(p).d;
      }

      function createBackgroundDots() {
        const targetGap = Math.max(8, Math.min(12, (cellH * 2) / 3));
        const dotCols = Math.max(2, Math.floor(cssWidth / targetGap));
        const dotRows = Math.max(2, Math.floor(cssHeight / targetGap));
        const gapX = cssWidth / (dotCols + 1);
        const gapY = cssHeight / (dotRows + 1);
        backgroundDots = [];

        for (let y = 1; y <= dotRows; y++) {
          for (let x = 1; x <= dotCols; x++) {
            backgroundDots.push({
              x: x * gapX,
              y: y * gapY,
              radius: 0.8,
              alpha: 0.2,
            });
          }
        }
      }

      function drawBackgroundDots() {
        for (const dot of backgroundDots) {
          ctx.fillStyle = `rgba(51, 51, 51, ${dot.alpha})`;
          ctx.beginPath();
          ctx.arc(dot.x, dot.y, dot.radius, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      function calcNormal(p) {
        const e = 0.005;
        const d = mapD(p);
        const nx = mapD([p[0] + e, p[1], p[2]]) - d;
        const ny = mapD([p[0], p[1] + e, p[2]]) - d;
        const nz = mapD([p[0], p[1], p[2] + e]) - d;
        return normalize([nx, ny, nz]);
      }

      function calcShadow(ro, rd) {
        let res = 1;
        let t = 0.05;
        for (let i = 0; i < 30; i++) {
          let d = mapD([ro[0] + rd[0] * t, ro[1] + rd[1] * t, ro[2] + rd[2] * t]);
          if (d < 0.002) return 0;
          res = Math.min(res, 15 * d / t);
          t += d;
          if (t > 6) break;
        }
        return Math.max(0, res);
      }

      function updateCamera() {
        const rect = decoration.getBoundingClientRect();
        const styles = getComputedStyle(decoration);
        cellW = parseFloat(styles.getPropertyValue("--asteroid-cell-w")) || 8;
        cellH = parseFloat(styles.getPropertyValue("--asteroid-cell-h")) || 16;
        cssWidth = Math.max(1, Math.floor(rect.width));
        cssHeight = Math.max(1, Math.floor(rect.height));
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        const nextWidth = Math.floor(cssWidth * dpr);
        const nextHeight = Math.floor(cssHeight * dpr);

        if (canvas.width !== nextWidth || canvas.height !== nextHeight) {
          canvas.width = nextWidth;
          canvas.height = nextHeight;
        }

        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.font = `bold ${cellH * 0.9}px monospace`;
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";

        cols = Math.max(1, Math.floor(cssWidth / cellW));
        rows = Math.max(1, Math.floor(cssHeight / cellH));

        rays = [];
        for (let y = 0; y < rows; y++) {
          let row = [];
          for (let x = 0; x < cols; x++) {
            let px = (x + 0.5) * cellW;
            let py = (y + 0.5) * cellH;
            let uvX = (px - cssWidth / 2) / cssHeight;
            let uvY = (py - cssHeight / 2) / cssHeight;

            let ro = [0, 0, -pCamDist];
            let rd = normalize([uvX, uvY, 2]);
            row.push({ ro, rd });
          }
          rays.push(row);
        }

        createBackgroundDots();
      }

      function getPointerDistance() {
        const pointers = Array.from(activePointers.values());
        if (pointers.length < 2) return null;
        return Math.hypot(pointers[0].x - pointers[1].x, pointers[0].y - pointers[1].y);
      }

      function clampCamera() {
        pCamDist = Math.max(3.5, Math.min(15, pCamDist));
      }

      canvas.addEventListener("pointerdown", (event) => {
        canvas.setPointerCapture(event.pointerId);
        activePointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
        lastMoveTime = Date.now();

        if (activePointers.size === 1) {
          isDragging = true;
          lastX = event.clientX;
          lastY = event.clientY;
          vRotX = 0;
          vRotY = 0;
          initialPinchDist = null;
        } else if (activePointers.size === 2) {
          isDragging = false;
          initialPinchDist = getPointerDistance();
          vZoom = 0;
        }
      });

      canvas.addEventListener("pointermove", (event) => {
        if (!activePointers.has(event.pointerId)) {
          return;
        }

        activePointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
        lastMoveTime = Date.now();

        if (activePointers.size >= 2 && initialPinchDist !== null) {
          event.preventDefault();
          const currentDist = getPointerDistance();
          if (currentDist !== null) {
            let delta = initialPinchDist - currentDist;
            vZoom = delta * 0.02;
            pCamDist += vZoom;
            clampCamera();
            initialPinchDist = currentDist;
            updateCamera();
          }
          return;
        }

        if (activePointers.size === 1 && isDragging) {
          event.preventDefault();
          let dx = event.clientX - lastX;
          let dy = event.clientY - lastY;
          lastX = event.clientX;
          lastY = event.clientY;
          vRotX = dx;
          vRotY = dy;
          applyDrag(vRotX, vRotY);
        }
      });

      function endPointer(event) {
        if (!activePointers.has(event.pointerId)) {
          return;
        }

        activePointers.delete(event.pointerId);
        if (canvas.hasPointerCapture(event.pointerId)) {
          canvas.releasePointerCapture(event.pointerId);
        }

        if (activePointers.size < 2) {
          if (Date.now() - lastMoveTime > 50) vZoom = 0;
          initialPinchDist = null;
        }

        if (activePointers.size === 1) {
          const remaining = Array.from(activePointers.values())[0];
          isDragging = true;
          lastX = remaining.x;
          lastY = remaining.y;
          vRotX = 0;
          vRotY = 0;
        } else {
          isDragging = false;
          if (Date.now() - lastMoveTime > 50) {
            vRotX = 0;
            vRotY = 0;
          }
        }
      }

      canvas.addEventListener("pointerup", endPointer);
      canvas.addEventListener("pointercancel", endPointer);
      canvas.addEventListener("wheel", (event) => {
        event.preventDefault();
        vZoom += event.deltaY * 0.002;
      }, { passive: false });

      function render(now) {
        time = now * 0.001;
        const deltaSeconds = lastFrameMs === null ? 0 : Math.min((now - lastFrameMs) * 0.001, 0.05);
        lastFrameMs = now;

        if (!isDragging && (Math.abs(vRotX) > 0.1 || Math.abs(vRotY) > 0.1)) {
          applyDrag(vRotX, vRotY);
          vRotX *= 0.92;
          vRotY *= 0.92;
        }

        const isAutoRotationPaused = isDragging || activePointers.size > 0 || Math.abs(vRotX) > 0.1 || Math.abs(vRotY) > 0.1;
        if (!isAutoRotationPaused) {
          applyAutoRotation(deltaSeconds);
        }

        if (Math.abs(vZoom) > 0.001 && initialPinchDist === null) {
          pCamDist += vZoom;
          clampCamera();
          vZoom *= 0.85;
          updateCamera();
        }

        const background = getComputedStyle(decoration).backgroundColor || "#fafaf9";
        ctx.fillStyle = background;
        ctx.fillRect(0, 0, cssWidth, cssHeight);
        drawBackgroundDots();

        const lightDir = normalize([0.8, 1.8, -1.2]);

        for (let y = 0; y < rows; y++) {
          for (let x = 0; x < cols; x++) {
            let ray = rays[y][x];
            let ro = ray.ro;
            let rd = ray.rd;

            let t = 0;
            let hit = false;
            let id = 0;
            let p;

            for (let i = 0; i < 60; i++) {
              p = [ro[0] + rd[0] * t, ro[1] + rd[1] * t, ro[2] + rd[2] * t];
              let res = map(p);
              if (res.d < 0.005) {
                hit = true;
                id = res.id;
                break;
              }
              t += res.d * 0.8;
              if (t > 20) break;
            }

            if (hit) {
              let n = calcNormal(p);
              let diff = Math.max(0, dot(n, lightDir));
              let shadow = calcShadow(p, lightDir);
              let rim = Math.pow(1 - Math.max(0, dot(n, [-rd[0], -rd[1], -rd[2]])), 2);

              let albedo = 1;
              let shade = 0;
              let char = " ";

              if (id === 1) {
                let pt = transformPoint(rotMatrix, p);
                let pAst = rotateY(pt, time * 0.4);

                let n1 = Math.sin(pAst[0] * 4) * Math.cos(pAst[1] * 5) * Math.sin(pAst[2] * 4);
                let n2 = Math.sin(pAst[0] * 12 - pAst[1] * 4) * Math.cos(pAst[2] * 12);
                let biome = n1 * 0.7 + n2 * 0.3;
                let poleDist = Math.abs(pAst[1] / pPlanetRadius);
                let isIce = poleDist > (0.8 + biome * 0.15);

                if (isIce) albedo = 0.95;
                else if (biome < -0.1) albedo = 0.35;
                else if (biome < 0.1) albedo = 0.5;
                else if (biome < 0.45) albedo = 0.65;
                else albedo = 0.8;

                let pCloud = rotateY(pt, time * 0.55);
                let cloudNoise = Math.sin(pCloud[0] * 5 / pPlanetRadius) * Math.cos(pCloud[1] * 7 / pPlanetRadius) * Math.sin(pCloud[2] * 5 / pPlanetRadius);
                let cloudCover = Math.max(0, cloudNoise - 0.2) * 1.8;
                cloudCover = Math.min(1, cloudCover);
                albedo = albedo * (1 - cloudCover) + 0.95 * cloudCover;

                let intensity = diff * shadow * albedo * 0.85 + 0.15;
                intensity += rim * 0.15 * albedo;
                intensity = Math.max(0, Math.min(1, intensity));

                shade = Math.floor(intensity * 130 + 20);
                let cIdx = Math.floor(intensity * CHARS.length);
                char = CHARS[Math.max(0, Math.min(CHARS.length - 1, cIdx))];
              } else if (id === 2) {
                let pt = transformPoint(rotMatrix, p);
                let pr = rotateY(pt, time * 0.15);
                let angle = Math.atan2(pr[2], pr[0]);
                let dist = Math.sqrt(pr[0] ** 2 + pr[2] ** 2) / pRingSize;

                let dust = Math.sin(angle * 12) * 0.1 + Math.cos(dist * 60) * 0.1;
                albedo = 0.8 + dust;

                let intensity = diff * shadow * albedo * 0.8 + 0.2;
                intensity += rim * 0.1;
                intensity = Math.max(0, Math.min(1, intensity));

                shade = Math.floor(intensity * 80 + 140);
                let cIdx = Math.floor(intensity * CHARS.length);
                char = CHARS[Math.max(0, Math.min(CHARS.length - 1, cIdx))];
              }

              if (char !== " ") {
                ctx.fillStyle = `rgb(${shade}, ${shade}, ${shade})`;
                ctx.fillText(char, x * cellW + cellW / 2, y * cellH + cellH / 2);
              }
            }
          }
        }

        requestAnimationFrame(render);
      }

      if ("ResizeObserver" in window) {
        const resizeObserver = new ResizeObserver(updateCamera);
        resizeObserver.observe(decoration);
      } else {
        window.addEventListener("resize", updateCamera);
      }

      updateCamera();
      requestAnimationFrame(render);
    }
  })();
</script>

<style>
  .asteroid-decoration {
    --asteroid-cell-w: 8;
    --asteroid-cell-h: 16;
    width: 100%;
    height: clamp(180px, 28vw, 320px);
    overflow: hidden;
    background: var(--color-bg);
  }

  .asteroid-decoration canvas {
    display: block;
    width: 100%;
    height: 100%;
    cursor: grab;
    touch-action: none;
  }

  .asteroid-decoration canvas:active {
    cursor: grabbing;
  }

  @media (max-width: 640px) {
    .asteroid-decoration {
      --asteroid-cell-w: 6;
      --asteroid-cell-h: 12;
      height: 180px;
    }
  }
</style>
