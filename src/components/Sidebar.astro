---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

type Post = CollectionEntry<"posts">;

const posts = (await getCollection("posts")).sort(
  (a: Post, b: Post) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = Array.from(
  new Set(posts.flatMap((post: Post) => post.data.categories))
).sort((a, b) => a.localeCompare(b, "en"));
const tags = Array.from(
  new Set(posts.flatMap((post: Post) => post.data.tags))
).sort((a, b) => a.localeCompare(b, "en"));
const recentPosts = posts.slice(0, 10);
const links = [
  {
    label: "Github",
    href: "https://github.com/kuyermqi",
  },
];

const taxonomyHref = (type: "category" | "tag", value: string) =>
  `/list?${type}=${encodeURIComponent(value)}`;
---

<aside class="sidebar" aria-label="Sidebar">
  <section class="sidebar-section">
    <h2 class="sidebar-title">Categories</h2>
    <ul class="sidebar-list">
      {categories.map((category) => <li><a href={taxonomyHref("category", category)}>{category}</a></li>)}
    </ul>
  </section>

  <section class="sidebar-section">
    <h2 class="sidebar-title">Tags</h2>
    <ul class="tag-list">
      {tags.map((tag) => <li><a href={taxonomyHref("tag", tag)}>{tag}</a></li>)}
    </ul>
  </section>

  <section class="sidebar-section">
    <h2 class="sidebar-title">Recent</h2>
    <ul class="sidebar-list recent-list">
      {recentPosts.map((post: Post) => <li><a href={`/posts/${post.id}`}>{post.data.title}</a></li>)}
    </ul>
  </section>

  <section class="sidebar-section">
    <h2 class="sidebar-title">Links</h2>
    <ul class="sidebar-list">
      {links.map((link) => (
        <li><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
      ))}
    </ul>
  </section>
</aside>

<style>
  .sidebar {
    width: 100%;
    color: var(--color-text-secondary);
  }

  .sidebar-section + .sidebar-section {
    margin-top: var(--space-xl);
  }

  .sidebar-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .sidebar-list,
  .tag-list {
    list-style: none;
    padding: 0;
  }

  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    column-gap: 0.75rem;
    row-gap: var(--space-xs);
  }

  .sidebar a {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .sidebar a:hover {
    color: var(--color-text);
  }

  .recent-list a {
    display: inline-block;
  }

  @media (max-width: 900px) {
    .sidebar {
      border-top: 1px solid var(--color-border);
      padding-top: var(--space-xl);
    }
  }
</style>
